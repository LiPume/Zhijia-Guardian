{
  "$defs": {
    "EvidenceRecord": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "title": "Evidence Id",
          "type": "string"
        },
        "metric_name": {
          "title": "Metric Name",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "threshold": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Threshold"
        },
        "time": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Time"
        },
        "status": {
          "default": "uncertain",
          "enum": [
            "normal",
            "violation",
            "uncertain"
          ],
          "title": "Status",
          "type": "string"
        },
        "supports": {
          "items": {
            "type": "string"
          },
          "title": "Supports",
          "type": "array"
        },
        "contradicts": {
          "items": {
            "type": "string"
          },
          "title": "Contradicts",
          "type": "array"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "metric_name"
      ],
      "title": "EvidenceRecord",
      "type": "object"
    },
    "ExpectedDiagnosis": {
      "additionalProperties": false,
      "properties": {
        "fault_type": {
          "title": "Fault Type",
          "type": "string"
        },
        "root_module": {
          "title": "Root Module",
          "type": "string"
        },
        "fault_start_time": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fault Start Time"
        }
      },
      "required": [
        "fault_type",
        "root_module"
      ],
      "title": "ExpectedDiagnosis",
      "type": "object"
    },
    "FailureSampleSource": {
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "title": "Dataset",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        },
        "raw_log_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Log Id"
        },
        "raw_tokens": {
          "additionalProperties": true,
          "title": "Raw Tokens",
          "type": "object"
        }
      },
      "required": [
        "dataset",
        "version"
      ],
      "title": "FailureSampleSource",
      "type": "object"
    },
    "RecommendedDataRecord": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "priority": {
          "enum": [
            "high",
            "medium",
            "low"
          ],
          "title": "Priority",
          "type": "string"
        }
      },
      "required": [
        "name",
        "reason",
        "priority"
      ],
      "title": "RecommendedDataRecord",
      "type": "object"
    },
    "RegressionTestConfig": {
      "additionalProperties": false,
      "properties": {
        "scenario_selector": {
          "$ref": "#/$defs/ScenarioSelector"
        },
        "diagnosis_input": {
          "const": "observed_view_only",
          "default": "observed_view_only",
          "title": "Diagnosis Input",
          "type": "string"
        },
        "method_under_test": {
          "title": "Method Under Test",
          "type": "string"
        },
        "threshold_config": {
          "title": "Threshold Config",
          "type": "string"
        },
        "llm_config": {
          "title": "Llm Config",
          "type": "string"
        },
        "expected": {
          "$ref": "#/$defs/ExpectedDiagnosis"
        },
        "tolerances": {
          "$ref": "#/$defs/RegressionTolerance"
        }
      },
      "required": [
        "scenario_selector",
        "method_under_test",
        "threshold_config",
        "llm_config",
        "expected"
      ],
      "title": "RegressionTestConfig",
      "type": "object"
    },
    "RegressionTolerance": {
      "additionalProperties": false,
      "properties": {
        "fault_start_time_abs_error_s": {
          "default": 0.5,
          "minimum": 0.0,
          "title": "Fault Start Time Abs Error S",
          "type": "number"
        }
      },
      "title": "RegressionTolerance",
      "type": "object"
    },
    "ScenarioSelector": {
      "additionalProperties": false,
      "properties": {
        "scenario_id": {
          "title": "Scenario Id",
          "type": "string"
        },
        "dataset": {
          "title": "Dataset",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        },
        "raw_log_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Log Id"
        }
      },
      "required": [
        "scenario_id",
        "dataset",
        "version"
      ],
      "title": "ScenarioSelector",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "failure_sample_v1",
      "default": "failure_sample_v1",
      "title": "Schema Version",
      "type": "string"
    },
    "package_kind": {
      "const": "diagnosis_failure_sample",
      "default": "diagnosis_failure_sample",
      "title": "Package Kind",
      "type": "string"
    },
    "oracle_visibility": {
      "const": "evaluation_only",
      "default": "evaluation_only",
      "title": "Oracle Visibility",
      "type": "string"
    },
    "scenario_id": {
      "title": "Scenario Id",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/FailureSampleSource"
    },
    "diagnosis_method": {
      "title": "Diagnosis Method",
      "type": "string"
    },
    "predicted_fault_type": {
      "title": "Predicted Fault Type",
      "type": "string"
    },
    "predicted_root_module": {
      "title": "Predicted Root Module",
      "type": "string"
    },
    "predicted_fault_start_time": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Predicted Fault Start Time"
    },
    "true_fault_type": {
      "title": "True Fault Type",
      "type": "string"
    },
    "true_root_module": {
      "title": "True Root Module",
      "type": "string"
    },
    "true_fault_start_time": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "True Fault Start Time"
    },
    "is_correct": {
      "title": "Is Correct",
      "type": "boolean"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceRecord"
      },
      "title": "Evidence",
      "type": "array"
    },
    "wrong_reasoning": {
      "title": "Wrong Reasoning",
      "type": "string"
    },
    "correct_reasoning": {
      "title": "Correct Reasoning",
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "recommended_data": {
      "items": {
        "$ref": "#/$defs/RecommendedDataRecord"
      },
      "title": "Recommended Data",
      "type": "array"
    },
    "regression_test_config": {
      "$ref": "#/$defs/RegressionTestConfig"
    },
    "scenario_record_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Scenario Record Hash",
      "type": "string"
    }
  },
  "required": [
    "scenario_id",
    "source",
    "diagnosis_method",
    "predicted_fault_type",
    "predicted_root_module",
    "true_fault_type",
    "true_root_module",
    "is_correct",
    "confidence",
    "wrong_reasoning",
    "correct_reasoning",
    "regression_test_config",
    "scenario_record_hash"
  ],
  "title": "FailureSampleRecord",
  "type": "object"
}
