{
  "$defs": {
    "VisualCondition": {
      "additionalProperties": false,
      "properties": {
        "lighting": {
          "enum": [
            "daylight",
            "night",
            "mixed",
            "uncertain"
          ],
          "title": "Lighting",
          "type": "string"
        },
        "weather": {
          "enum": [
            "clear",
            "rain",
            "fog",
            "snow",
            "mixed",
            "uncertain"
          ],
          "title": "Weather",
          "type": "string"
        },
        "visibility": {
          "enum": [
            "good",
            "moderate",
            "poor",
            "uncertain"
          ],
          "title": "Visibility",
          "type": "string"
        },
        "road_context": {
          "title": "Road Context",
          "type": "string"
        }
      },
      "required": [
        "lighting",
        "weather",
        "visibility",
        "road_context"
      ],
      "title": "VisualCondition",
      "type": "object"
    },
    "VisualObservation": {
      "additionalProperties": false,
      "properties": {
        "observation_id": {
          "title": "Observation Id",
          "type": "string"
        },
        "category": {
          "enum": [
            "road_user",
            "occlusion",
            "visibility",
            "possible_miss",
            "possible_false_positive",
            "class_ambiguity",
            "temporal_change",
            "other"
          ],
          "title": "Category",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "frame_indices": {
          "items": {
            "type": "integer"
          },
          "minItems": 1,
          "title": "Frame Indices",
          "type": "array"
        },
        "related_evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Related Evidence Ids",
          "type": "array"
        }
      },
      "required": [
        "observation_id",
        "category",
        "description",
        "confidence",
        "frame_indices"
      ],
      "title": "VisualObservation",
      "type": "object"
    },
    "VisualReviewOutput": {
      "additionalProperties": false,
      "properties": {
        "conditions": {
          "$ref": "#/$defs/VisualCondition"
        },
        "observations": {
          "items": {
            "$ref": "#/$defs/VisualObservation"
          },
          "title": "Observations",
          "type": "array"
        },
        "suspected_fault_type": {
          "enum": [
            "normal",
            "perception_miss",
            "perception_false_positive",
            "perception_confidence_drop",
            "perception_class_confusion",
            "uncertain"
          ],
          "title": "Suspected Fault Type",
          "type": "string"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "assessment": {
          "title": "Assessment",
          "type": "string"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Limitations",
          "type": "array"
        }
      },
      "required": [
        "conditions",
        "suspected_fault_type",
        "confidence",
        "assessment",
        "limitations"
      ],
      "title": "VisualReviewOutput",
      "type": "object"
    },
    "VisualSampleFrame": {
      "additionalProperties": false,
      "properties": {
        "frame_index": {
          "minimum": 0,
          "title": "Frame Index",
          "type": "integer"
        },
        "timestamp": {
          "minimum": 0.0,
          "title": "Timestamp",
          "type": "number"
        },
        "image_path": {
          "title": "Image Path",
          "type": "string"
        },
        "image_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Image Sha256",
          "type": "string"
        }
      },
      "required": [
        "frame_index",
        "timestamp",
        "image_path",
        "image_sha256"
      ],
      "title": "VisualSampleFrame",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "visual_review_v1",
      "default": "visual_review_v1",
      "title": "Schema Version",
      "type": "string"
    },
    "scenario_id": {
      "title": "Scenario Id",
      "type": "string"
    },
    "method": {
      "enum": [
        "direct_vlm",
        "vlm_with_tools"
      ],
      "title": "Method",
      "type": "string"
    },
    "provider": {
      "title": "Provider",
      "type": "string"
    },
    "model": {
      "title": "Model",
      "type": "string"
    },
    "oracle_used": {
      "const": false,
      "default": false,
      "title": "Oracle Used",
      "type": "boolean"
    },
    "annotation_images_used": {
      "const": false,
      "default": false,
      "title": "Annotation Images Used",
      "type": "boolean"
    },
    "sampled_frames": {
      "items": {
        "$ref": "#/$defs/VisualSampleFrame"
      },
      "minItems": 1,
      "title": "Sampled Frames",
      "type": "array"
    },
    "output": {
      "$ref": "#/$defs/VisualReviewOutput"
    },
    "metadata": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "integer"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ]
      },
      "title": "Metadata",
      "type": "object"
    }
  },
  "required": [
    "scenario_id",
    "method",
    "provider",
    "model",
    "sampled_frames",
    "output"
  ],
  "title": "VisualReviewRecord",
  "type": "object"
}
