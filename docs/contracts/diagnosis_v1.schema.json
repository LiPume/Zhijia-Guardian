{
  "$defs": {
    "AgentStepRecord": {
      "additionalProperties": false,
      "properties": {
        "agent_name": {
          "title": "Agent Name",
          "type": "string"
        },
        "status": {
          "default": "completed",
          "enum": [
            "completed",
            "skipped",
            "uncertain"
          ],
          "title": "Status",
          "type": "string"
        },
        "summary": {
          "default": "",
          "title": "Summary",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "output": {
          "additionalProperties": true,
          "title": "Output",
          "type": "object"
        }
      },
      "required": [
        "agent_name"
      ],
      "title": "AgentStepRecord",
      "type": "object"
    },
    "CandidateRootCause": {
      "additionalProperties": false,
      "properties": {
        "fault_type": {
          "title": "Fault Type",
          "type": "string"
        },
        "root_module": {
          "title": "Root Module",
          "type": "string"
        },
        "score": {
          "default": 0.0,
          "title": "Score",
          "type": "number"
        },
        "confidence": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "rationale": {
          "default": "",
          "title": "Rationale",
          "type": "string"
        }
      },
      "required": [
        "fault_type",
        "root_module"
      ],
      "title": "CandidateRootCause",
      "type": "object"
    },
    "ClaimRecord": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "claim": {
          "title": "Claim",
          "type": "string"
        },
        "predicted_fault_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Predicted Fault Type"
        },
        "predicted_root_module": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Predicted Root Module"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        }
      },
      "required": [
        "claim_id",
        "claim"
      ],
      "title": "ClaimRecord",
      "type": "object"
    },
    "EvidenceRecord": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "title": "Evidence Id",
          "type": "string"
        },
        "metric_name": {
          "title": "Metric Name",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "threshold": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Threshold"
        },
        "time": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Time"
        },
        "status": {
          "default": "uncertain",
          "enum": [
            "normal",
            "violation",
            "uncertain"
          ],
          "title": "Status",
          "type": "string"
        },
        "supports": {
          "items": {
            "type": "string"
          },
          "title": "Supports",
          "type": "array"
        },
        "contradicts": {
          "items": {
            "type": "string"
          },
          "title": "Contradicts",
          "type": "array"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "metric_name"
      ],
      "title": "EvidenceRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "diagnosis_v1",
      "default": "diagnosis_v1",
      "title": "Schema Version",
      "type": "string"
    },
    "scenario_id": {
      "title": "Scenario Id",
      "type": "string"
    },
    "predicted_fault_type": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Predicted Fault Type"
    },
    "predicted_root_module": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Predicted Root Module"
    },
    "predicted_fault_start_time": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Predicted Fault Start Time"
    },
    "confidence": {
      "default": 0.0,
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "method": {
      "default": "rule_only",
      "title": "Method",
      "type": "string"
    },
    "candidate_root_causes": {
      "items": {
        "$ref": "#/$defs/CandidateRootCause"
      },
      "title": "Candidate Root Causes",
      "type": "array"
    },
    "agent_trace": {
      "items": {
        "$ref": "#/$defs/AgentStepRecord"
      },
      "title": "Agent Trace",
      "type": "array"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceRecord"
      },
      "title": "Evidence",
      "type": "array"
    },
    "claims": {
      "items": {
        "$ref": "#/$defs/ClaimRecord"
      },
      "title": "Claims",
      "type": "array"
    }
  },
  "required": [
    "scenario_id"
  ],
  "title": "DiagnosisRecord",
  "type": "object"
}
